# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json              # json (production) or console (development)

# CORS
ALLOWED_ORIGINS=*            # comma-separated origins, e.g. https://virtughan.com,https://app.virtughan.com

# Rate Limiting (slowapi format: "count/period")
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_EXPORT=10/minute
RATE_LIMIT_TILE=120/minute

# Input Limits
MAX_BBOX_AREA_SQ_DEG=25.0
MAX_DATE_RANGE_DAYS=1825

# Server
REQUEST_TIMEOUT=120

# Storage
STATIC_DIR=static
STATIC_EXPORT_DIR=static/export
EXPIRY_DURATION_HOURS=1
